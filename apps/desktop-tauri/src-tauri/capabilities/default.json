{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Permissions for the desktop shell: spawn the backend sidecar and check for updates.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-navigate",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "bin/frontier-backend", "sidecar": true }]
    },
    "updater:default"
  ]
}
