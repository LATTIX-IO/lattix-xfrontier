DATABASE_URL=postgresql://lattix:lattix@postgres:5432/lattix
FRONTIER_STATE_STORE=.frontier/state.db
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token
OPA_ADDR=http://opa:8181
NATS_URL=nats://nats:4222
JAEGER_ENDPOINT=http://jaeger:4317
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
A2A_JWT_ALG=HS256
A2A_JWT_ISS=lattix-frontier
A2A_JWT_AUD=agents
A2A_JWT_SECRET=
A2A_REQUIRE_NONCE=true
A2A_REPLAY_PROTECTION=true
A2A_CLOCK_SKEW_SECONDS=30
A2A_REPLAY_TTL_SECONDS=900
A2A_TRUSTED_SUBJECTS=orchestrator,research,code,review,coordinator
BISCUIT_ROOT_SECRET=change-me-in-production
JWT_SECRET=change-me-too
SANDBOX_RUNNER_IMAGE=python:3.12-slim
SANDBOX_INTERNAL_NETWORK=frontier-sandbox-internal
SANDBOX_EGRESS_GATEWAY=sandbox-egress-gateway:3128
SANDBOX_WORKSPACE_ROOT=.sandbox
SANDBOX_ALLOW_LIVE_EXECUTION=false
LOCAL_STACK_HOST=frontier.localhost
LOCAL_GATEWAY_HTTP_PORT=80
NEXT_PUBLIC_API_BASE_URL=/api
INSTALLER_PUBLIC_REPO=https://github.com/LATTIX-IO/lattix-xfrontier.git
INSTALLER_DEFAULT_REF=main
FEDERATION_ENABLED=false
FEDERATION_CLUSTER_NAME=local-frontier
FEDERATION_REGION=local
