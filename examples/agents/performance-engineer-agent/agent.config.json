{
  "id": "performance-engineer-agent",
  "name": "Performance Engineer Agent",
  "description": "Reviews a proposed change for performance and leanness: algorithmic complexity, unnecessary work, allocations, N+1 and IO patterns, and over-engineering. Reads the diff and returns structured findings with a verdict. The team's efficiency seat.",
  "version": 1,
  "status": "active",
  "tags": ["swe", "performance", "efficiency", "lean", "team", "oss"],
  "capabilities": ["performance-review", "complexity-analysis", "leanness"],
  "owners": ["oss-maintainers"],
  "prompt_file": "system-prompt.md",
  "url_manifest": "url-manifest.json",
  "model_defaults": {
    "provider": "ollama",
    "model": "gpt-oss:20b",
    "temperature": 0.2,
    "top_p": 0.95,
    "capability_profile": "local-32b-class"
  },
  "tools": [
    {
      "name": "repo-read",
      "type": "frontier-coding",
      "config": { "toolset": ["execute_bash", "search", "str_replace_editor"], "mode": "read-only" }
    }
  ]
}
