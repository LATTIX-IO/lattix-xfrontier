{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattix.ai/schemas/url-manifest.schema.json",
  "title": "URL Manifest",
  "type": "object",
  "required": ["reference_manifest_version", "agent", "sources"],
  "properties": {
    "reference_manifest_version": { "type": "string" },
    "agent": { "type": "string" },
    "last_verified": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "type"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "type": { "type": "string" },
          "scope": { "type": "array", "items": { "type": "string" } },
          "stability": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}

