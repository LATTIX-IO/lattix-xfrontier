{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattix.ai/schemas/envelope.schema.json",
  "title": "Message Envelope",
  "type": "object",
  "required": ["schema_version", "id", "correlation_id", "msg_type", "sender", "topic", "payload"],
  "properties": {
    "schema_version": { "type": "string" },
    "id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "causality": { "type": "string" },
    "created_at_ms": { "type": "integer" },
    "msg_type": { "type": "string" },
    "sender": { "type": "string" },
    "topic": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "budget": {
      "type": "object",
      "properties": {
        "cost_limit_tokens": { "type": ["integer", "null"] },
        "time_limit_ms": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },
    "payload": { "type": "object" },
    "errors": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}

